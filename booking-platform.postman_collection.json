{
  "info": {
    "name": "booking-platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health (gateway)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        },
        {
          "name": "GET /auth/ping (auth-service)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/ping"
          }
        },
        {
          "name": "GET /companies/ping (company-service)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/companies/ping"
          }
        },
        {
          "name": "GET /bookings/ping (booking-service)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/bookings/ping"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"firstName\": \"New\",\n  \"lastName\": \"User\",\n  \"email\": \"newuser@test.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "POST /auth/register-admin",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register-admin",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newadmin\",\n  \"firstName\": \"New\",\n  \"lastName\": \"Admin\",\n  \"email\": \"newadmin@test.com\",\n  \"password\": \"password123\",\n  \"companyId\": 2,\n  \"role\": \"ADMIN\"\n}"
            }
          }
        },
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "const token = response.token;",
                  "pm.environment.set(\"token\", token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "GET /internal/users?ids=",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/internal/users?ids=1,2,3"
          }
        },
        {
          "name": "GET /internal/users/:id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/internal/users/1"
          }
        },
        {
          "name": "GET /internal/users/by-company",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/internal/users/by-company?companyId=1&role=OPERATOR",
              "host": ["{{base_url}}"],
              "path": ["internal", "users", "by-company"],
              "query": [
                { "key": "companyId", "value": "1" },
                { "key": "role", "value": "OPERATOR" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Companies",
      "item": [
        {
          "name": "GET /companies",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/companies"
          }
        },
        {
          "name": "GET /companies/:id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/companies/1"
          }
        },
        {
          "name": "POST /companies",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/companies",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Peluquería Franco\",\n  \"description\": \"Cortes de pelo\",\n  \"address\": \"Av. Siempre Viva 123\",\n  \"phone\": \"1234567890\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Services",
      "item": [
        {
          "name": "GET /services (paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/services?page=0&size=10&sort=name,asc",
              "host": ["{{base_url}}"],
              "path": ["services"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sort", "value": "name,asc" },
                { "key": "companyId", "value": "1", "disabled": true },
                { "key": "name", "value": "corte", "disabled": true },
                { "key": "minPrice", "value": "1000", "disabled": true },
                { "key": "maxPrice", "value": "5000", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "GET /companies/:id/services",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/companies/1/services"
          }
        },
        {
          "name": "POST /companies/:id/services",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/companies/1/services",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alisado\",\n  \"description\": \"Alisado completo\",\n  \"durationMinutes\": 90,\n  \"price\": 12000.00\n}"
            }
          }
        },
        {
          "name": "PATCH /services/:id",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/services/1",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 5500.00\n}"
            }
          }
        },
        {
          "name": "PATCH /services/:id/activate",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/services/1/activate",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "PATCH /services/:id/deactivate",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/services/1/deactivate",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "GET /internal/services?ids=",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/internal/services?ids=1,2,3"
          }
        },
        {
          "name": "GET /internal/services/:id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/internal/services/1"
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "POST /bookings",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/bookings",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"service_id\": 1,\n  \"company_id\": 1,\n  \"start_time\": \"2026-03-15T10:00:00\",\n  \"end_time\": \"2026-03-15T10:30:00\",\n  \"price\": 5000.00\n}"
            }
          }
        },
        {
          "name": "GET /bookings/my",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/bookings/my",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "GET /bookings/company",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/bookings/company",
              "host": ["{{base_url}}"],
              "path": ["bookings", "company"],
              "query": [
                { "key": "status", "value": "PENDING", "disabled": true },
                { "key": "from_date", "value": "2026-04-01", "disabled": true },
                { "key": "to_date", "value": "2026-04-30", "disabled": true },
                { "key": "full_name", "value": "garcia", "disabled": true }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "GET /bookings/:id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/bookings/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "PATCH /bookings/:id/confirm",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/bookings/1/confirm",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "PATCH /bookings/:id/complete",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/bookings/1/complete",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "PATCH /bookings/:id/cancel",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/bookings/1/cancel",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "PATCH /bookings/:id/reschedule",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/bookings/1/reschedule",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"start_time\": \"2026-03-20T10:00:00\",\n  \"end_time\": \"2026-03-20T10:30:00\"\n}"
            }
          }
        },
        {
          "name": "GET /bookings/stats",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/bookings/stats?from_date=2026-04-01T00:00:00&to_date=2026-04-30T23:59:59",
              "host": ["{{base_url}}"],
              "path": ["bookings", "stats"],
              "query": [
                { "key": "from_date", "value": "2026-04-01T00:00:00" },
                { "key": "to_date", "value": "2026-04-30T23:59:59" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    }
  ]
}
