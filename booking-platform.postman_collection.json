{
  "info": {
    "name": "booking-platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "url": "{{auth_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"franchute\",\n  \"email\": \"francocatania@gmail.com\",\n  \"password\": \"123456\",\n  \"companyId\": 1\n}"
            }
          }
        },
        {
          "name": "POST /auth/register-admin",
          "request": {
            "method": "POST",
            "url": "{{auth_url}}/auth/register-admin",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"123456\",\n  \"companyId\": 1\n}"
            }
          }
        },
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "const token = response.token;",
                  "pm.environment.set(\"token\", token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{auth_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"francocatania@gmail.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Companies",
      "item": [
        {
          "name": "GET /companies",
          "request": {
            "method": "GET",
            "url": "{{company_url}}/companies"
          }
        },
        {
          "name": "GET /companies/:id",
          "request": {
            "method": "GET",
            "url": "{{company_url}}/companies/1"
          }
        },
        {
          "name": "POST /companies",
          "request": {
            "method": "POST",
            "url": "{{company_url}}/companies",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Peluquería Franco\",\n  \"description\": \"Cortes de pelo\",\n  \"address\": \"Av. Siempre Viva 123\",\n  \"phone\": \"1234567890\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Services",
      "item": [
        {
          "name": "GET /companies/:id/services",
          "request": {
            "method": "GET",
            "url": "{{company_url}}/companies/1/services"
          }
        },
        {
          "name": "POST /companies/:id/services",
          "request": {
            "method": "POST",
            "url": "{{company_url}}/companies/1/services",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Corte clásico\",\n  \"description\": \"Corte con tijera\",\n  \"durationMinutes\": 30,\n  \"price\": 1500.00\n}"
            }
          }
        },
        {
          "name": "PATCH /services/:id",
          "request": {
            "method": "PATCH",
            "url": "{{company_url}}/services/1",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 2000.00\n}"
            }
          }
        },
        {
          "name": "PATCH /services/:id/activate",
          "request": {
            "method": "PATCH",
            "url": "{{company_url}}/services/1/activate",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "PATCH /services/:id/deactivate",
          "request": {
            "method": "PATCH",
            "url": "{{company_url}}/services/1/deactivate",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    }
  ]
}
